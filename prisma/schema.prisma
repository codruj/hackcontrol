generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model Widget {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
}

model Hackathon {
  id                  String               @id @default(cuid())
  name                String
  url                 String               @unique
  description         String?
  rules               String?
  criteria            String?
  prizes              String?
  matchmaking         String?
  categories          String?
  organizers          String?
  judges_info         String?
  timeline            Json?
  sponsors            Json?
  sponsors_text       String?
  creatorId           String
  updatedAt           DateTime             @default(now()) @updatedAt
  is_finished              Boolean              @default(false)
  verified                 Boolean              @default(false)
  min_judges_required      Int                  @default(2)
  max_winners_displayed    Int                  @default(3)
  announcements       Announcement[]
  owner               User                 @relation(fields: [creatorId], references: [id])
  Judge               Judge[]
  participations      Participation[]
  judgingCriteria     Criterion[]
  hackathonCategories HackathonCategory[]
  volunteers          Volunteer[]
  volunteerTasks      VolunteerTask[]
  mentors             Mentor[]
  mentorSlots         MentorSlot[]
  chatChannels        ChatChannel[]

  @@unique([url, creatorId])
  @@map("hackathons")
}

model Participation {
  id             String             @id @default(cuid())
  is_reviewed    Boolean            @default(false)
  is_winner      Boolean            @default(false)
  title          String
  description    String
  project_url    String
  presentation_url String?
  hackathon_name String
  hackathon_url  String
  creatorId      String
  creatorName    String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  team_members   Json?
  categoryId     String?
  createdBy      User               @relation(fields: [creatorId], references: [id])
  hackathon      Hackathon          @relation(fields: [hackathon_url], references: [url], onDelete: Cascade)
  scores         Score[]
  judgeNotes     JudgeNote[]
  category       HackathonCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([creatorId, hackathon_url])
  @@map("participations")
}

model Score {
  id              String        @id @default(cuid())
  judgeId         String
  participationId String
  criterionId     String?
  score           Int
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  judge           Judge         @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  participation   Participation @relation(fields: [participationId], references: [id], onDelete: Cascade)
  criterion       Criterion?    @relation(fields: [criterionId], references: [id], onDelete: SetNull)

  @@unique([judgeId, participationId, criterionId])
  @@map("scores")
}

model Criterion {
  id          String    @id @default(cuid())
  name        String
  weight      Float
  order       Int
  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  scores      Score[]

  @@map("criteria")
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  important   Boolean   @default(false)
  hackathonId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id               String          @id @default(cuid())
  name             String?
  username         String?         @unique
  email            String?         @unique
  emailVerified    DateTime?
  image            String?
  role             Role            @default(USER)
  access           Boolean         @default(true)
  accounts         Account[]
  hackathons       Hackathon[]
  invitedJudges    Judge[]         @relation("JudgeInviter")
  judgedHackathons Judge[]
  participations   Participation[]
  sessions         Session[]
  invitedVolunteers    Volunteer[]     @relation("VolunteerInviter")
  volunteerAssignments Volunteer[]
  createdVolunteerTasks VolunteerTask[] @relation("VolunteerTaskCreator")
  invitedMentors       Mentor[]        @relation("MentorInviter")
  mentorAssignments    Mentor[]
  bookedSlots          MentorSlot[]    @relation("SlotBooker")
  chatMessages         ChatMessage[]

  @@map("users")
}

model Judge {
  id              String          @id @default(cuid())
  userId          String
  hackathonId     String
  invitedBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  hackathon       Hackathon       @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  inviter         User            @relation("JudgeInviter", fields: [invitedBy], references: [id])
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores          Score[]
  judgeCategories JudgeCategory[]
  judgeNotes      JudgeNote[]

  @@unique([userId, hackathonId])
  @@map("judges")
}

model HackathonCategory {
  id                   String          @id @default(cuid())
  hackathonId          String
  name                 String
  description          String?
  max_winners_displayed Int?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  hackathon      Hackathon       @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  participations Participation[]
  judgeCategories JudgeCategory[]

  @@unique([hackathonId, name])
  @@map("hackathon_categories")
}

model JudgeCategory {
  id         String            @id @default(cuid())
  judgeId    String
  categoryId String
  judge      Judge             @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  category   HackathonCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([judgeId, categoryId])
  @@map("judge_categories")
}

model JudgeNote {
  id              String        @id @default(cuid())
  judgeId         String
  participationId String
  note            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  judge           Judge         @relation(fields: [judgeId], references: [id], onDelete: Cascade)
  participation   Participation @relation(fields: [participationId], references: [id], onDelete: Cascade)

  @@unique([judgeId, participationId])
  @@map("judge_notes")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum Role {
  ADMIN
  ORGANIZER
  USER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Volunteer {
  id          String    @id @default(cuid())
  userId      String
  hackathonId String
  invitedById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  inviter     User      @relation("VolunteerInviter", fields: [invitedById], references: [id])
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskAssignments VolunteerTaskAssignment[]

  @@unique([userId, hackathonId])
  @@map("volunteers")
}

model VolunteerTask {
  id          String     @id @default(cuid())
  title       String
  description String?
  deadline    DateTime?
  status      TaskStatus @default(TODO)
  hackathonId String
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  hackathon   Hackathon  @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  createdBy   User       @relation("VolunteerTaskCreator", fields: [createdById], references: [id])
  assignees   VolunteerTaskAssignment[]

  @@map("volunteer_tasks")
}

model VolunteerTaskAssignment {
  taskId      String
  volunteerId String
  task        VolunteerTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  volunteer   Volunteer     @relation(fields: [volunteerId], references: [id], onDelete: Cascade)

  @@id([taskId, volunteerId])
  @@map("volunteer_task_assignments")
}

enum ChannelType {
  MENTORS_PARTICIPANTS
  MENTORS_JUDGES
  VOLUNTEERS_PARTICIPANTS
  VOLUNTEERS_ONLY
  TEAM_ONLY
}

model Mentor {
  id          String       @id @default(cuid())
  userId      String
  hackathonId String
  invitedById String
  bio         String?
  expertise   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  hackathon   Hackathon    @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  inviter     User         @relation("MentorInviter", fields: [invitedById], references: [id])
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  slots       MentorSlot[]

  @@unique([userId, hackathonId])
  @@map("mentors")
}

model MentorSlot {
  id          String    @id @default(cuid())
  mentorId    String
  hackathonId String
  startTime   DateTime
  endTime     DateTime
  topic       String?
  isBooked    Boolean   @default(false)
  bookedById  String?
  bookingNote String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  mentor      Mentor    @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  bookedBy    User?     @relation("SlotBooker", fields: [bookedById], references: [id])

  @@map("mentor_slots")
}

model ChatChannel {
  id              String      @id @default(cuid())
  key             String      @unique
  hackathonId     String
  type            ChannelType
  participationId String?
  name            String
  createdAt       DateTime    @default(now())
  hackathon       Hackathon   @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  messages        ChatMessage[]

  @@map("chat_channels")
}

model ChatMessage {
  id        String      @id @default(cuid())
  channelId String
  userId    String
  content   String
  createdAt DateTime    @default(now())
  channel   ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id])

  @@map("chat_messages")
}

enum crdb_internal_region {
  aws_eu_central_1 @map("aws-eu-central-1")
}
